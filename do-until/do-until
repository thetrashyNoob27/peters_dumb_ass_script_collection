#!/bin/bash

function usage() {
    echo "Usage: $(basename "$0") [-n pause_time] [-r success_code] [-m max_retries] command [args...]"
    echo ""
    echo "Options:"
    echo "  -n pause_time    Seconds to sleep between retries (default: 1)"
    echo "  -r success_code  Exit code to treat as success (default: 0)"
    echo "  -m max_retries   Maximum number of attempts (default: unlimited)"
    echo "  -h               Show this help message"
}

fail_pause_time=1
success_return_code=0
max_retries=0

while getopts ":n:r:m:h" opt; do
    case $opt in
        n)
            fail_pause_time="$OPTARG"
            ;;
        r)
            success_return_code="$OPTARG"
            ;;
        m)
            max_retries="$OPTARG"
            ;;
        h)
            usage
            exit 0
            ;;
        \?)
            echo "Unknown option: -$OPTARG" >&2
            usage >&2
            exit 1
            ;;
        :)
            echo "Option -$OPTARG requires an argument." >&2
            usage >&2
            exit 1
            ;;
    esac
done

shift $((OPTIND - 1))

if [[ $# -eq 0 ]]; then
    echo "Error: No command specified." >&2
    usage >&2
    exit 1
fi

if ! [[ "$success_return_code" =~ ^[0-9]+$ ]]; then
    echo "success_return_code value is $success_return_code, not an integer." >&2
    exit 1
fi

if ! [[ "$fail_pause_time" =~ ^[+-]?[0-9]+(\.[0-9]+)?$ ]]; then
    echo "fail_pause_time is $fail_pause_time, not a valid number." >&2
    exit 1
fi

if (( max_retries < 0 )) || ! [[ "$max_retries" =~ ^[0-9]+$ ]]; then
    echo "max_retries is $max_retries, not a valid non-negative integer." >&2
    exit 1
fi

echo "fail_pause_time:$fail_pause_time"
echo "success_return_code:$success_return_code"

run_commands=("$@")
echo "cmd:${run_commands[*]}"

cnt=0
pass=-1

while true; do
    ((cnt++))

    "${run_commands[@]}"
    pass=$?

    echo "return value:${pass} expected value:${success_return_code} try count:${cnt}"

    if (( pass == success_return_code )); then
        break
    fi

    if (( max_retries > 0 && cnt >= max_retries )); then
        echo "Reached max retry limit ($max_retries), giving up." >&2
        exit 1
    fi

    sleep "$fail_pause_time"
done

echo "total try count:$cnt"
exit 0
